<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_generate_alerts" model="ir.cron">
            <field name="name">Génération des alertes garanties/contrats</field>
            <field name="model_id" ref="model_it_alert"/>
            <field name="state">code</field>
            <field name="code">model.cron_generate_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="cron_check_contract_expiry" model="ir.cron">
            <field name="name">Vérification expiration des contrats</field>
            <field name="model_id" ref="model_it_contract"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
