<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="report_equipment_card" model="ir.actions.report">
        <field name="name">Fiche équipement</field>
        <field name="model">it.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_equipment_card_template</field>
        <field name="print_report_name">'Fiche_%s' % object.name</field>
    </record>

    <record id="report_inventory" model="ir.actions.report">
        <field name="name">Inventaire</field>
        <field name="model">it.equipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventory_template</field>
        <field name="print_report_name">'Inventaire_parc'</field>
    </record>

    <record id="report_maintenance_history" model="ir.actions.report">
        <field name="name">Historique maintenances</field>
        <field name="model">it.intervention</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_maintenance_template</field>
        <field name="print_report_name">'Maintenances_%s' % (time.strftime('%%Y%%m%%d'))</field>
    </record>
</odoo>
