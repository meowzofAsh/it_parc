<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_contract_tree" model="ir.ui.view">
        <field name="name">it.contract.tree</field>
        <field name="model">it.contract</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="days_remaining"/>
                <field name="amount"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_it_contract_form" model="ir.ui.view">
        <field name="name">it.contract.form</field>
        <field name="model">it.contract</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="days_remaining"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <field name="equipment_ids">
                        <tree>
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="category"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
