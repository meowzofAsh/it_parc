<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_equipment_tree" model="ir.ui.view">
        <field name="name">it.equipment.tree</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="category"/>
                <field name="state" widget="badge" decoration-success="state == 'assigned'" decoration-warning="state == 'maintenance'" decoration-muted="state == 'retired'"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="warranty_date"/>
            </list>
        </field>
    </record>

    <record id="view_it_equipment_form" model="ir.ui.view">
        <field name="name">it.equipment.form</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_assign" string="Affecter" type="object"
                            states="draft" class="btn-primary"/>
                    <button name="action_maintenance" string="Mettre en maintenance" type="object"
                            states="assigned" class="btn-warning"/>
                    <button name="action_retire" string="Retirer du parc" type="object"
                            states="draft,assigned,maintenance" class="btn-danger"/>
                    <button name="action_draft" string="Remettre en brouillon" type="object"
                            states="retired" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,assigned,maintenance,retired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_reassign" string="Réaffecter" type="object"
                                class="oe_stat_button" icon="fa-exchange"
                                help="Réaffecter cet équipement à un autre employé"/>
                        <button name="%(it_parc.report_equipment_card)d" string="Fiche"
                                type="action" class="oe_stat_button" icon="fa-file-pdf-o"
                                help="Fiche équipement PDF"/>
                        <button name="%(it_parc.report_inventory)d" string="Inventaire"
                                type="action" class="oe_stat_button" icon="fa-print"
                                help="Rapport inventaire complet"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="purchase_value" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="purchase_date"/>
                            <field name="warranty_date"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="employee_id"/>
                        <field name="department_id"/>
                        <field name="contract_id"/>
                    </group>
                    <notebook>
                        <page name="interventions" string="Interventions">
                            <field name="intervention_ids">
                                <list>
                                    <field name="type"/>
                                    <field name="technician_id"/>
                                    <field name="start_date"/>
                                    <field name="cost"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page name="assignments" string="Historique des affectations">
                            <field name="assignment_ids">
                                <list>
                                    <field name="employee_id"/>
                                    <field name="department_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="note"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_equipment_search" model="ir.ui.view">
        <field name="name">it.equipment.search</field>
        <field name="model">it.equipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="employee_id"/>
                <filter name="filter_assigned" string="Affectés" domain="[('state','=','assigned')]"/>
                <filter name="filter_maintenance" string="En maintenance" domain="[('state','=','maintenance')]"/>
                <separator/>
                <filter name="filter_warranty" string="Garantie expirée" domain="[('warranty_date','&lt;',time.strftime('%%Y-%%m-%%d'))]"/>
                <group expand="0" string="Group by">
                    <filter name="group_category" string="Catégorie" context="{'group_by':'category'}"/>
                    <filter name="group_state" string="État" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
