<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_intervention_tree" model="ir.ui.view">
        <field name="name">it.intervention.tree</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <list>
                <field name="equipment_id"/>
                <field name="type"/>
                <field name="technician_id"/>
                <field name="start_date"/>
                <field name="duration"/>
                <field name="cost"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_it_intervention_form" model="ir.ui.view">
        <field name="name">it.intervention.form</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Démarrer" type="object"
                            states="planned" class="btn-primary"/>
                    <button name="action_done" string="Terminer" type="object"
                            states="in_progress" class="btn-success"/>
                    <field name="state" widget="statusbar" statusbar_visible="planned,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(it_parc.report_maintenance_history)d" string="Historique"
                                type="action" class="oe_stat_button" icon="fa-history"
                                help="Historique des maintenances PDF"/>
                    </div>
                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="type"/>
                            <field name="technician_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration"/>
                            <field name="cost"/>
                        </group>
                    </group>
                    <field name="report"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_intervention_calendar" model="ir.ui.view">
        <field name="name">it.intervention.calendar</field>
        <field name="model">it.intervention</field>
        <field name="arch" type="xml">
            <calendar date_start="start_date" date_stop="end_date" color="technician_id">
                <field name="equipment_id"/>
                <field name="type"/>
            </calendar>
        </field>
    </record>
</odoo>
