<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="Dashboard" name="it_parc Dashboard">
        <div class="o_dashboard">
            <div class="o_dashboard_kpis">
                <div class="o_kpi_card">
                    <span class="o_kpi_value" t-esc="state.kpis.total_equipments"/>
                    <span class="o_kpi_label">Total équipements</span>
                </div>
                <div class="o_kpi_card">
                    <span class="o_kpi_value" t-esc="state.kpis.total_value"/>
                    <span class="o_kpi_label">Valeur totale du parc (FCFA)</span>
                </div>
                <div class="o_kpi_card">
                    <span class="o_kpi_value" t-esc="state.kpis.maintenance_cost"/>
                    <span class="o_kpi_label">Coût maintenances (mois)</span>
                </div>
                <div class="o_kpi_card">
                    <span class="o_kpi_value" t-esc="state.kpis.top_panne_count"/>
                    <span class="o_kpi_label">Équipements en maintenance</span>
                </div>
            </div>
            <div class="o_dashboard_chart">
                <canvas id="dashboardChart" width="400" height="300"/>
            </div>
        </div>
    </template>
</odoo>
