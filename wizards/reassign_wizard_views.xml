<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_reassign_wizard_form" model="ir.ui.view">
        <field name="name">reassign.wizard.form</field>
        <field name="model">reassign.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="equipment_id"/>
                    <field name="employee_id"/>
                    <field name="department_id"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_reassign" string="Réaffecter" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
