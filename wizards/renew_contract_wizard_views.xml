<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_renew_contract_wizard_form" model="ir.ui.view">
        <field name="name">renew.contract.wizard.form</field>
        <field name="model">renew.contract.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="contract_id"/>
                    <field name="new_end_date"/>
                    <field name="new_amount"/>
                </group>
                <footer>
                    <button name="action_renew" string="Renouveler" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
