<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_csv_wizard_form" model="ir.ui.view">
        <field name="name">import.csv.wizard.form</field>
        <field name="model">import.csv.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename"/>
                </group>
                <footer>
                    <button name="action_import" string="Importer" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
