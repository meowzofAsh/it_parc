<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_excel_export_wizard_form" model="ir.ui.view">
        <field name="name">excel.export.wizard.form</field>
        <field name="model">excel.export.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="export_type"/>
                </group>
                <footer>
                    <button name="action_export" string="Exporter" type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
